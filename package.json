    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "better-auth": "^1.6.13",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
